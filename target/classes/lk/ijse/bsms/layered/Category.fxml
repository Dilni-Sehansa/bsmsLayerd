<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="category_Form" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.bsms.layered.controller.CategoryController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="86.0" style="-fx-background-color: linear-gradient(to right, #10B981, #059669); -fx-background-radius: 15;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="📑 Category Management" textFill="WHITE" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="25.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                    <effect>
                        <DropShadow blurType="THREE_PASS_BOX" color="#00000020" offsetY="3.0" radius="10.0" />
                    </effect>
                </HBox>

                <VBox alignment="TOP_CENTER" layoutX="8.0" layoutY="92.0" prefWidth="469.0" spacing="15.0" style="-fx-background-radius: 20; -fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="28.0" AnchorPane.leftAnchor="8.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <Label text="Category Details" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="15.0" top="30.0" />
                            </VBox.margin>
                        </Label>

                        <HBox alignment="CENTER" spacing="15">
                            <children>
                                <TextField fx:id="categoryID" onKeyPressed="#handleSearchCategory" prefHeight="50.0" prefWidth="400.0" promptText="🔍  Search by Category ID" style="-fx-background-color: #F9FAFB; -fx-border-color: #10B981; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 20 0 20; -fx-font-size: 15;" HBox.hgrow="ALWAYS" />
                            </children>
                            <VBox.margin>
                                <Insets left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>

                        <VBox spacing="10">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Category Name">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="categoryName" prefHeight="50.0" promptText="Enter category name" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 14;">
                                    <font>
                                        <Font name="Segoe UI" size="15.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" top="20.0" />
                            </VBox.margin>
                        </VBox>

                        <VBox VBox.vgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="12">
                            <children>
                                <Button fx:id="category_Add_Button" mnemonicParsing="false" onAction="#handleSaveCategory" prefHeight="50.0" prefWidth="130.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✓ Add">
                                    <font>
                                        <Font name="Segoe UI Bold" size="15.0" />
                                    </font>
                                </Button>
                                <Button fx:id="category_Update_Button" mnemonicParsing="false" onAction="#handleCategoryUpdate" prefHeight="50.0" prefWidth="130.0" style="-fx-background-color: #3B82F6; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="↻ Update">
                                    <font>
                                        <Font name="Segoe UI Bold" size="15.0" />
                                    </font>
                                </Button>
                                <Button fx:id="category_Delete_Button" mnemonicParsing="false" onAction="#handleCategoryDelete" prefHeight="50.0" prefWidth="130.0" style="-fx-background-color: #EF4444; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✕ Delete">
                                    <font>
                                        <Font name="Segoe UI Bold" size="15.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="25.0" left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>

                <VBox layoutX="484.0" layoutY="100.0" prefWidth="612.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="28.0" AnchorPane.leftAnchor="484.0" AnchorPane.rightAnchor="4.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <Label text="Category Records" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="20.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="categoryTable" prefHeight="380.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="category_Id_Column" prefWidth="200.0" text="Category ID" />
                                <TableColumn fx:id="category_Name_Column" prefWidth="400.0" text="Category Name" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" />
                            </VBox.margin>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>