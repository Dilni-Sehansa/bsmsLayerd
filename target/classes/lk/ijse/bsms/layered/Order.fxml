<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="order_Form" maxHeight="Infinity" maxWidth="Infinity" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.bsms.layered.controller.OrderController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="86.0" style="-fx-background-color: linear-gradient(to right, #10B981, #059669); -fx-background-radius: 15;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="🛒 Order Management" textFill="WHITE" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="25.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                    <effect>
                        <DropShadow color="#00000020" offsetY="3.0" radius="10.0" />
                    </effect>
                </HBox>

                <!-- Left Panel - Order Form -->
                <VBox prefHeight="651.0" prefWidth="450.0" spacing="3.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="49.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Form Title -->
                        <Label text="Order Details" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets left="25.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <!-- Customer Section -->
                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Customer Information">
                                    <font>
                                        <Font name="Segoe UI Bold" size="15.0" />
                                    </font>
                                </Label>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Customer ID">
                                            <font>
                                                <Font name="Segoe UI Semibold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="comboCustomerId" prefWidth="400.0" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Name">
                                                    <font>
                                                        <Font name="Segoe UI" size="11.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblCustomerNameValue" style="-fx-text-fill: #10B981; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="16.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Contact">
                                                    <font>
                                                        <Font name="Segoe UI" size="11.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblCustomerNumberValue" style="-fx-text-fill: #10B981; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="16.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Email">
                                            <font>
                                                <Font name="Segoe UI" size="11.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblCustomerAddressValue" style="-fx-text-fill: #10B981; -fx-font-weight: bold;" text="-" wrapText="true">
                                            <font>
                                                <Font name="Segoe UI Bold" size="16.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin>
                                <Insets left="25.0" right="25.0" />
                            </VBox.margin>
                        </VBox>

                        <Separator style="-fx-background-color: #E5E7EB;" />

                        <!-- Item Section -->
                        <VBox prefHeight="285.0" prefWidth="397.0" spacing="5.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Item Selection">
                                    <font>
                                        <Font name="Segoe UI Bold" size="15.0" />
                                    </font>
                                </Label>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Item ID">
                                            <font>
                                                <Font name="Segoe UI Semibold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="comboItemId" prefWidth="400.0" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Item Name">
                                                    <font>
                                                        <Font name="Segoe UI" size="11.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblItemNameValue" style="-fx-text-fill: #3B82F6; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="16.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Available QTY">
                                                    <font>
                                                        <Font name="Segoe UI" size="11.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblItemQtyValue" style="-fx-text-fill: #3B82F6; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="16.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Unit Price">
                                                    <font>
                                                        <Font name="Segoe UI" size="11.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblItemPriceValue" style="-fx-text-fill: #3B82F6; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Quantity">
                                                    <font>
                                                        <Font name="Segoe UI Semibold" size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="qtyField" prefHeight="40.0" promptText="Enter quantity" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                                    <font>
                                                        <Font name="Segoe UI" size="14.0" />
                                                    </font>
                                                </TextField>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                            <VBox.margin>
                                <Insets left="25.0" right="25.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER" prefHeight="118.0" prefWidth="397.0" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="40.0" prefWidth="175.0" style="-fx-background-color: #6B7280; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Reset">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#6B728030" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#btnAddToCartOnAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Add to Cart">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#10B98130" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>

                <!-- Right Panel - Cart Table -->
                <VBox prefHeight="651.0" prefWidth="620.0" spacing="5.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="49.0" AnchorPane.leftAnchor="470.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Table Title -->
                        <Label text="Shopping Cart" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="20.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="orderTable" style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="item_Name_Column" prefWidth="120.0" style="-fx-alignment: CENTER-LEFT;" text="Item Name" />
                                <TableColumn fx:id="unit_price_Column" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Unit Price" />
                                <TableColumn fx:id="qty_Column" prefWidth="80.0" style="-fx-alignment: CENTER;" text="QTY" />
                                <TableColumn fx:id="total_price_Column" minWidth="0.0" prefWidth="110.0" style="-fx-alignment: CENTER-RIGHT;" text="Total Price" />
                                <TableColumn fx:id="action_Column" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <VBox.margin>
                                <Insets left="15.0" right="15.0" />
                            </VBox.margin>
                        </TableView>

                        <!-- Order Summary & Actions -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #F9FAFB; -fx-background-radius: 12; -fx-padding: 15;">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 13;" text="Order Total">
                                            <font>
                                                <Font name="Segoe UI Semibold" size="13.0" />
                                            </font>
                                        </Label>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 16;" text="Rs.">
                                                    <font>
                                                        <Font name="Segoe UI" size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblOrderTotal" style="-fx-text-fill: #10B981; -fx-font-weight: bold;" text="-">
                                                    <font>
                                                        <Font name="Segoe UI Bold" size="24.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#btnResetOnActionlast" prefHeight="50.0" prefWidth="100.0" style="-fx-background-color: #6B7280; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Reset">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                            <effect>
                                                <DropShadow color="#6B728030" offsetY="2.0" radius="6.0" />
                                            </effect>
                                        </Button>
                                        <Button mnemonicParsing="false" onAction="#btnPlaceOrderOnAction" prefHeight="50.0" prefWidth="123.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✓ Place Order">
                                            <font>
                                                <Font name="Segoe UI Bold" size="15.0" />
                                            </font>
                                            <effect>
                                                <DropShadow color="#10B98130" offsetY="2.0" radius="8.0" />
                                            </effect>
                                        </Button>
                              <Button mnemonicParsing="false" onAction="#btnSalesReportOnAction" prefHeight="50.0" prefWidth="110.0" style="-fx-background-radius: 10; -fx-background-color: orange;" text="Report" textFill="#f8f8f8">
                                 <font>
                                    <Font name="Segoe UI Bold" size="12.0" />
                                 </font>
                              </Button>
                                    </children>
                                </HBox>
                            </children>
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</StackPane>
