<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="profile_Form" maxHeight="Infinity" maxWidth="Infinity" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.bsms.layered.controller.ProfileController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="86.0" style="-fx-background-color: linear-gradient(to right, #10B981, #059669); -fx-background-radius: 15;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="👤 Profile Management" textFill="WHITE" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="25.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                    <effect>
                        <DropShadow color="#00000020" offsetY="3.0" radius="10.0" />
                    </effect>
                </HBox>

                <!-- Left Panel - Form -->
                <VBox alignment="TOP_CENTER" prefWidth="469.0" spacing="5.0" style="-fx-background-radius: 20; -fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Title -->
                        <Label text="User Profile" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <!-- Search Field -->
                        <HBox alignment="CENTER" prefHeight="70.0" prefWidth="450.0" spacing="15">
                            <children>
                                <TextField fx:id="user_ID" onKeyPressed="#searchUser" prefHeight="45.0" prefWidth="400.0" promptText="🔍  Search by User ID" style="-fx-background-color: #F9FAFB; -fx-border-color: #10B981; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 20 0 20; -fx-font-size: 14;" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>

                        <!-- User Name Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="User Name">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="user_Name" prefHeight="40.0" promptText="Enter full name" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" top="5.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Password Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Password">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="user_password" prefHeight="40.0" promptText="Enter password" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </PasswordField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Role Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="User Role">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="role" prefHeight="40.0" prefWidth="400.0" promptText="Select role" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <VBox.margin>
                                        <Insets />
                                    </VBox.margin>
                                </ComboBox>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Spacer -->
                        <VBox VBox.vgrow="ALWAYS" />

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER" prefHeight="80.0" prefWidth="450.0" spacing="12">
                            <children>
                                <Button fx:id="user_Add_Button" mnemonicParsing="false" onAction="#addUser" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✓ Add" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#10B98130" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button fx:id="user_Update_Button" mnemonicParsing="false" onAction="#updateUser" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #3B82F6; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="↻ Update" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#3B82F630" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button fx:id="user_Delete_Button" mnemonicParsing="false" onAction="#deleteUser" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #EF4444; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✕ Delete" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#EF444430" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="15.0" left="20.0" right="20.0" top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>


                <!-- Right Panel - Table -->
                <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="489.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Table Title -->
                        <Label text="User Records" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="20.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="userTable" style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="user_Id_Column" prefWidth="100.0" style="-fx-alignment: CENTER;" text="User ID" />
                                <TableColumn fx:id="user_Name_Column" prefWidth="150.0" style="-fx-alignment: CENTER-LEFT;" text="User Name" />
                                <TableColumn fx:id="user_password_Column" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Password" />
                                <TableColumn fx:id="role_Column" minWidth="0.0" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Role" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" />
                            </VBox.margin>
                        </TableView>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</StackPane>
