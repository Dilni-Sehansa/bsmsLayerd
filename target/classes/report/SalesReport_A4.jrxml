<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SalesReport_A4" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter"/>
    <queryString language="SQL">
        <![CDATA[SELECT
            o.orderId,
            o.orderDate,
            c.cusName,
            od.itemId,
            od.qty,
            od.amount,
            (od.qty * od.amount) AS subTotal
        FROM bookshop.orders o
        JOIN bookshop.customer c ON o.cusId = c.cusId
        JOIN bookshop.order_details od ON o.orderId = od.orderId
        ORDER BY o.orderId DESC]]>
    </queryString>
    <field name="orderId" class="java.lang.Long"/>
    <field name="orderDate" class="java.sql.Timestamp"/>
    <field name="cusName" class="java.lang.String"/>
    <field name="itemId" class="java.lang.Long"/>
    <field name="qty" class="java.lang.Integer"/>
    <field name="amount" class="java.math.BigDecimal"/>
    <field name="subTotal" class="java.math.BigDecimal"/>
    <variable name="GrandTotal" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{subTotal}]]></variableExpression>
    </variable>
    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[SHANI BOOKSHOP]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true" isUnderline="true"/>
                </textElement>
                <text><![CDATA[SALES REPORT]]></text>
            </staticText>
        </band>
    </title>
    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement mode="Opaque" x="0" y="0" width="60" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Order ID]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="60" y="0" width="140" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Customer Name]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="200" y="0" width="80" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Item ID]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="280" y="0" width="50" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="330" y="0" width="100" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Unit Price]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="430" y="0" width="125" height="30" backcolor="#E0E0E0"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Sub Total]]></text>
            </staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="25">
            <textField>
                <reportElement x="0" y="0" width="60" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{orderId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60" y="0" width="140" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement verticalAlignment="Middle"><paragraph leftIndent="5"/></textElement>
                <textFieldExpression><![CDATA[$F{cusName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="80" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{itemId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="280" y="0" width="50" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{qty}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="330" y="0" width="100" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><paragraph rightIndent="5"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="430" y="0" width="125" height="25"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><paragraph rightIndent="5"/></textElement>
                <textFieldExpression><![CDATA[$F{subTotal}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    <summary>
        <band height="50">
            <staticText>
                <reportElement x="330" y="10" width="100" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Grand Total: ]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="430" y="10" width="125" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="12" isBold="true" isUnderline="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{GrandTotal}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>