<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="item_Form" maxHeight="Infinity" maxWidth="Infinity" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.bsms.layered.controller.ItemController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="86.0" style="-fx-background-color: linear-gradient(to right, #10B981, #059669); -fx-background-radius: 15;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="📦 Item Management" textFill="WHITE" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="25.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                    <effect>
                        <DropShadow color="#00000020" offsetY="3.0" radius="10.0" />
                    </effect>
                </HBox>

                <!-- Left Panel - Form -->
                <VBox alignment="TOP_CENTER" prefHeight="690.0" prefWidth="469.0" style="-fx-background-radius: 20; -fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Title -->
                        <Label text="Item Details" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="5.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <!-- Search Field -->
                        <HBox alignment="CENTER" prefHeight="65.0" prefWidth="450.0">
                            <children>
                                <TextField fx:id="itemId" onKeyPressed="#handleSearchItem" prefHeight="42.0" prefWidth="400.0" promptText="🔍  Search by Item ID" style="-fx-background-color: #F9FAFB; -fx-border-color: #10B981; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 20 0 20; -fx-font-size: 14;" HBox.hgrow="ALWAYS">

                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="20.0" right="20.0" />
                            </VBox.margin>
                        </HBox>

                        <!-- Received Price Field -->
                        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                            <children>
                        <VBox spacing="3.0">
                           <children>
                              <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Item Name">
                                 <font>
                                    <Font name="Segoe UI Semibold" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="itemName" prefHeight="32.0" promptText="Enter Item Name" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                 <font>
                                    <Font name="Segoe UI" size="13.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Received Price">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="itemRecivedPrice" prefHeight="32.0" promptText="Rs. 0.00" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="13.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" top="3.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Selling Price Field -->
                        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Selling Price">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="itemPrice" prefHeight="32.0" promptText="Rs. 0.00" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="13.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>
                  <VBox spacing="3.0">
                     <children>
                        <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Qty">
                           <font>
                              <Font name="Segoe UI Semibold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="itemPrice1" prefHeight="32.0" prefWidth="395.0" promptText="0" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                           <font>
                              <Font name="Segoe UI" size="13.0" />
                           </font>
                        </TextField>
                     </children>
                     <VBox.margin>
                        <Insets left="30.0" right="30.0" />
                     </VBox.margin>
                  </VBox>

                        <!-- Status Field -->
                        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Stock Status">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="itemStatus" prefHeight="32.0" promptText="Available / Low Stock / Out of Stock" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="13.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Category ID Dropdown -->
                        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Category">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="cmbCategoryId" opacity="0.41" prefHeight="38.0" prefWidth="400.0" promptText="Select category" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10;" />
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Supplier ID Dropdown -->
                        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Supplier">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="cmbSupplierId" opacity="0.46" prefHeight="38.0" prefWidth="400.0" promptText="Select supplier" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10;" />
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER" prefHeight="75.0" prefWidth="450.0" spacing="12.0">
                            <children>
                                <Button fx:id="item_Add_Button" mnemonicParsing="false" onAction="#handleSaveItem" prefHeight="42.0" prefWidth="130.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✓ Add" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#10B98130" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button fx:id="item_Update_Button" mnemonicParsing="false" onAction="#handleItemUpdate" prefHeight="42.0" prefWidth="130.0" style="-fx-background-color: #3B82F6; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="↻ Update" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#3B82F630" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button fx:id="item_Delete_Button" mnemonicParsing="false" onAction="#handleItemDelete" prefHeight="42.0" prefWidth="130.0" style="-fx-background-color: #EF4444; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✕ Delete" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#EF444430" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="15.0" left="20.0" right="20.0" top="5.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>


                <!-- Right Panel - Table -->
                <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="489.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Table Title -->
                        <Label text="Item Records" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="20.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="itemTable" onSort="#handleItemUpdate" prefHeight="561.0" prefWidth="567.0" style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="item_Id_Column" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Item ID" />
                                <TableColumn fx:id="item_name_Column" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Item Name" />
                                <TableColumn fx:id="item_recived_price_Column" prefWidth="78.0" style="-fx-alignment: CENTER-RIGHT;" text="Receivede" />
                                <TableColumn fx:id="price_Column" minWidth="0.0" prefWidth="71.99993896484375" style="-fx-alignment: CENTER;" text="Selling" />
                                <TableColumn fx:id="categoryId_Column" prefWidth="74.00006103515625" style="-fx-alignment: CENTER;" text="Category" />
                                <TableColumn fx:id="supId_Column" prefWidth="62.0" style="-fx-alignment: CENTER;" text="Supplier" />
                        <TableColumn fx:id="status_Column" prefWidth="65.33334350585938" text="Status" />
                        <TableColumn fx:id="qty_Column" prefWidth="62.666717529296875" text="Qty" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" />
                            </VBox.margin>
                        </TableView>
                  <Button mnemonicParsing="false" onAction="#handleCustomerPrint" prefHeight="41.0" prefWidth="130.0" style="-fx-background-color: orange; -fx-background-radius: 10;" text="Report" textFill="WHITE">
                     <VBox.margin>
                        <Insets bottom="15.0" left="380.0" />
                     </VBox.margin>
                     <font>
                        <Font name="Segoe UI Bold" size="12.0" />
                     </font>
                  </Button>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</StackPane>
