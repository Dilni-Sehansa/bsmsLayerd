<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="return_Form" maxHeight="Infinity" maxWidth="Infinity" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.bsms.layered.controller.ReturnController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="86.0" style="-fx-background-color: linear-gradient(to right, #10B981, #059669); -fx-background-radius: 15;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="↩️ Return Management" textFill="WHITE" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="25.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                    <effect>
                        <DropShadow color="#00000020" offsetY="3.0" radius="10.0" />
                    </effect>
                </HBox>

                <!-- Left Panel - Form -->
                <VBox alignment="TOP_CENTER" prefWidth="469.0" spacing="12.0" style="-fx-background-radius: 20; -fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Title -->
                        <Label text="Return Details" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="5.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <!-- Order ID Search Field -->
                        <VBox spacing="8">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Order ID">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <HBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="txtOrderId" onKeyPressed="#handleSearchOrder" prefHeight="42.0" promptText="Enter Order ID" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font name="Segoe UI" size="14.0" />
                                            </font>
                                        </TextField>
                                        <Button mnemonicParsing="false" onAction="#handleSearchOrderBtn" prefHeight="42.0" prefWidth="90.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔍 Search">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                            <effect>
                                                <DropShadow color="#10B98130" offsetY="2.0" radius="6.0" />
                                            </effect>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" top="5.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Item ID Field -->
                        <!-- Item ID Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Item ID">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <!-- FIXED fx:id -->
                                <ComboBox fx:id="txtItemId" prefHeight="20.0" prefWidth="406.0" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10;" />
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Quantity Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Return Quantity">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtQty" prefHeight="40.0" promptText="Enter quantity" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Description Field -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Return Description">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="txtDescription" prefHeight="100.0" promptText="Describe the reason for return..." style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10;" wrapText="true">
                                    <font>
                                        <Font name="Segoe UI" size="13.0" />
                                    </font>
                                </TextArea>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Resellable Checkbox -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <children>
                                <CheckBox fx:id="cbResellable" style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Item is Resellable (Update Stock)">
                                    <font>
                                        <Font name="Segoe UI Semibold" size="13.0" />
                                    </font>
                                </CheckBox>
                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 11;" text="Check this if the returned item can be added back to inventory" wrapText="true">
                                    <font>
                                        <Font name="Segoe UI" size="11.0" />
                                    </font>
                                </Label>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Spacer -->
                        <VBox VBox.vgrow="ALWAYS" />

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER" prefHeight="80.0" prefWidth="450.0" spacing="12">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleClear" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #6B7280; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Clear" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#6B728030" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#handleConfirmReturn" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #10B981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✓ Confirm Return" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                    <effect>
                                        <DropShadow color="#10B98130" offsetY="2.0" radius="6.0" />
                                    </effect>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="15.0" left="20.0" right="20.0" top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>


                <!-- Right Panel - Table -->
                <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 20; -fx-border-width: 1;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="489.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <!-- Table Title -->
                        <Label text="Return Records" textFill="#10B981">
                            <font>
                                <Font name="Segoe UI Semibold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="20.0" top="20.0" />
                            </VBox.margin>
                        </Label>

                        <TableView fx:id="returnTable" style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colReturnId" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Return ID" />
                                <TableColumn fx:id="colOrderId" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Order ID" />
                                <TableColumn fx:id="colDescription" prefWidth="380.0" style="-fx-alignment: CENTER-LEFT;" text="Description" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <VBox.margin>
                                <Insets bottom="15.0" left="15.0" right="15.0" />
                            </VBox.margin>
                        </TableView>
                    </children>
                    <effect>
                        <DropShadow color="#00000010" offsetY="3.0" radius="15.0" />
                    </effect>
                </VBox>

            </children>
         <StackPane.margin>
            <Insets />
         </StackPane.margin>
        </AnchorPane>
    </children>
</StackPane>
